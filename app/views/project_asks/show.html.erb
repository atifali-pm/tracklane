<% content_for :title, "Ask #{@project.name}" %>

<div class="px-6 py-6 max-w-3xl">
  <div class="mb-4">
    <%= link_to @project.name, @project, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-white" %>
  </div>

  <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-1">Ask <%= @project.name %></h1>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
    Answers draw only from this project's indexed issues, comments, and description.
  </p>

  <% unless ProjectAskService.enabled? %>
    <div class="mb-6 bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-900 text-amber-800 dark:text-amber-200 rounded-md p-3 text-sm">
      AI chat is off. Set <code class="bg-amber-100 dark:bg-amber-900/50 px-1 py-0.5 rounded text-[11px]">ANTHROPIC_API_KEY</code>
      and <code class="bg-amber-100 dark:bg-amber-900/50 px-1 py-0.5 rounded text-[11px]">OPENAI_API_KEY</code>, restart the server,
      then run <code class="bg-amber-100 dark:bg-amber-900/50 px-1 py-0.5 rounded text-[11px]">bin/db rake ai:embed_backfill</code>
      to index existing data.
    </div>
  <% end %>

  <%= form_with url: project_ask_path(@project), method: :post, class: "mb-6" do |f| %>
    <div class="flex gap-2">
      <%= f.text_area :question,
            rows: 3,
            value: @question,
            placeholder: "What is the current status of the mobile launch? Who is working on the typography pair?",
            class: "flex-1 block rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:outline-blue-600 px-3 py-2 text-sm" %>
      <%= f.submit "Ask",
            class: "self-start bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:hover:bg-white cursor-pointer" %>
    </div>
  <% end %>

  <% if @result %>
    <section class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md p-5 mb-6">
      <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-2">Answer</div>
      <div class="text-sm text-gray-800 dark:text-gray-200 whitespace-pre-wrap leading-relaxed">
        <%= answer_with_links(@result[:answer], @project) %>
      </div>
    </section>

    <% if @result[:chunks].any? %>
      <section>
        <div class="text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-2">Sources (<%= @result[:chunks].size %>)</div>
        <ul class="space-y-2">
          <% @result[:chunks].each_with_index do |chunk, i| %>
            <% meta = chunk.metadata || {} %>
            <li class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md p-3 text-sm">
              <div class="flex items-center justify-between mb-1">
                <div class="text-xs text-gray-500 dark:text-gray-400 font-mono">
                  [<%= i + 1 %>]
                  <% if meta["kind"] == "issue" %>
                    <%= link_to "#{meta['project_slug']}-##{meta['number']}",
                          project_issue_path(meta['project_slug'], meta['number']),
                          class: "text-gray-700 dark:text-gray-300 hover:underline" %>
                  <% elsif meta["kind"] == "comment" %>
                    <%= link_to "#{meta['project_slug']}-##{meta['issue_number']} comment",
                          project_issue_path(meta['project_slug'], meta['issue_number']),
                          class: "text-gray-700 dark:text-gray-300 hover:underline" %>
                  <% else %>
                    <%= meta['kind'] %>
                  <% end %>
                </div>
              </div>
              <div class="text-xs text-gray-600 dark:text-gray-400 line-clamp-3 whitespace-pre-wrap">
                <%= chunk.content %>
              </div>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>
  <% end %>
</div>
