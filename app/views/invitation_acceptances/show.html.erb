<div class="max-w-md mx-auto py-16 px-4">
  <div class="bg-white border border-gray-200 rounded-md p-8 text-center">
    <h1 class="text-xl font-semibold mb-2">You are invited</h1>
    <p class="text-gray-600 mb-1">
      <span class="font-medium text-gray-900"><%= @invitation.invited_by.email_address %></span>
      invited you to join
    </p>
    <p class="text-lg font-semibold text-gray-900 mb-1"><%= @invitation.organization.name %></p>
    <p class="text-sm text-gray-500 mb-6 capitalize">
      as a <%= @invitation.role %>
    </p>

    <% if Current.user.nil? %>
      <p class="text-sm text-gray-600 mb-4">
        Sign in with <span class="font-medium"><%= @invitation.email %></span> to accept.
      </p>
      <%= link_to "Sign in", new_session_path,
            class: "block bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800" %>
    <% elsif Current.user.email_address == @invitation.email %>
      <%= button_to "Accept invitation", invitation_acceptance_path(token: @invitation.token),
            method: :post,
            class: "w-full bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 cursor-pointer" %>
    <% else %>
      <p class="text-sm text-red-700 mb-2">
        You are signed in as <%= Current.user.email_address %>.
      </p>
      <p class="text-sm text-gray-600 mb-4">
        This invitation is for <%= @invitation.email %>. Sign out and sign back in with the invited email.
      </p>
      <%= button_to "Sign out", session_path, method: :delete,
            class: "block w-full border border-gray-300 rounded-md px-4 py-2 text-sm hover:bg-gray-100 cursor-pointer" %>
    <% end %>
  </div>
</div>
