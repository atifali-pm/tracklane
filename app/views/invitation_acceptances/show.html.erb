<div class="max-w-md mx-auto py-16 px-4">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md p-8 text-center">
    <h1 class="text-xl font-semibold mb-2">You are invited</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-1">
      <span class="font-medium text-gray-900 dark:text-gray-100"><%= @invitation.invited_by.email_address %></span>
      invited you to join
    </p>
    <p class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1"><%= @invitation.organization.name %></p>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 capitalize">
      as a <%= @invitation.role %>
    </p>

    <% if Current.user.nil? %>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Sign in with <span class="font-medium text-gray-900 dark:text-gray-100"><%= @invitation.email %></span> to accept.
      </p>
      <%= link_to "Sign in", new_session_path,
            class: "block bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
    <% elsif Current.user.email_address == @invitation.email %>
      <%= button_to "Accept invitation", invitation_acceptance_path(token: @invitation.token),
            method: :post,
            class: "w-full bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white cursor-pointer" %>
    <% else %>
      <p class="text-sm text-red-700 dark:text-red-300 mb-2">
        You are signed in as <%= Current.user.email_address %>.
      </p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        This invitation is for <%= @invitation.email %>. Sign out and sign back in with the invited email.
      </p>
      <%= button_to "Sign out", session_path, method: :delete,
            class: "block w-full border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-md px-4 py-2 text-sm hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer" %>
    <% end %>
  </div>
</div>
