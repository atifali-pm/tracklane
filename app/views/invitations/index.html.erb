<div class="max-w-3xl mx-auto py-10 px-4">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Invitations</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400">Pending invites for <%= current_organization.name %>.</p>
    </div>
    <%= link_to "New invitation", new_invitation_path,
          class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
  </div>

  <% if @pending.any? %>
    <ul class="divide-y divide-gray-200 dark:divide-gray-800 border border-gray-200 dark:border-gray-800 rounded-md bg-white dark:bg-gray-900">
      <% @pending.each do |invitation| %>
        <li class="px-4 py-4">
          <div class="flex items-center justify-between mb-2">
            <div>
              <div class="font-medium text-gray-900 dark:text-gray-100"><%= invitation.email %></div>
              <div class="text-xs text-gray-500 dark:text-gray-400 capitalize">
                <%= invitation.role %>
                <span class="text-gray-400 dark:text-gray-500">·</span>
                invited by <%= invitation.invited_by.email_address %>
                <span class="text-gray-400 dark:text-gray-500">·</span>
                expires <%= time_ago_in_words(invitation.expires_at) %> from now
              </div>
            </div>
            <%= button_to "Revoke", invitation_path(invitation.token),
                  method: :delete,
                  data: { turbo_confirm: "Revoke invitation for #{invitation.email}?" },
                  class: "text-sm border border-red-300 dark:border-red-900 text-red-700 dark:text-red-300 rounded-md px-3 py-1.5 hover:bg-red-50 dark:hover:bg-red-900/30 cursor-pointer" %>
          </div>
          <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md px-3 py-2 text-xs text-gray-700 dark:text-gray-300 break-all">
            <%= url_for controller: "invitation_acceptances", action: :show, token: invitation.token, only_path: false, host: request.host_with_port %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-md p-8 text-center bg-white dark:bg-gray-900">
      <p class="text-gray-600 dark:text-gray-400 mb-4">No pending invitations.</p>
      <%= link_to "Invite someone", new_invitation_path,
            class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
    </div>
  <% end %>
</div>
