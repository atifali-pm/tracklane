<div class="max-w-xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to "All invitations", invitations_path, class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>

  <h1 class="text-2xl font-semibold mb-6">Invite someone to <%= current_organization.name %></h1>

  <%= form_with model: @invitation, class: "space-y-5" do |f| %>
    <% if @invitation.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 rounded-md p-3 text-sm">
        <ul class="list-disc list-inside space-y-1">
          <% @invitation.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, required: true, autofocus: true,
            class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :role, Invitation.roles.keys.map { |r| [ r.humanize, r ] }, { selected: "member" },
            class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
    </div>

    <p class="text-xs text-gray-500">
      Invitations expire in 7 days. Email delivery lands in Phase 5; for now,
      share the generated link manually.
    </p>

    <div class="flex items-center gap-3">
      <%= f.submit "Send invitation", class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 cursor-pointer" %>
      <%= link_to "Cancel", invitations_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
