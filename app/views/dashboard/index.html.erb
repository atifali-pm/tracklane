<% content_for :title, "Home" %>

<% if current_organization %>
  <div class="px-6 py-6 max-w-6xl">
    <div class="mb-8">
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">
        <%= greeting %>, <%= Current.user.email_address.split("@").first.capitalize %>.
      </h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Here's what's happening in <%= current_organization.name %> today.
      </p>
    </div>

    <% if @pending_invitations_count.to_i > 0 %>
      <div class="mb-8 bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-900 rounded-md px-4 py-3 flex items-center justify-between">
        <div class="text-sm text-indigo-900 dark:text-indigo-200">
          <%= pluralize(@pending_invitations_count, 'pending invitation') %> waiting for acceptance.
        </div>
        <%= link_to "Manage", invitations_path, class: "text-sm font-medium text-indigo-700 dark:text-indigo-300 hover:underline" %>
      </div>
    <% end %>

    <!-- Recent projects -->
    <section class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Recent projects</h2>
        <%= link_to "View all", projects_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
      </div>

      <% if @recent_projects.any? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @recent_projects.each do |project| %>
            <% total = project.issues.size %>
            <% done = project.issues.count { |i| i.status == "done" } %>
            <% progress = total.zero? ? 0 : ((done.to_f / total) * 100).round %>
            <%= link_to project, class: "block p-4 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg hover:shadow-sm transition" do %>
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full <%= project.active? ? 'bg-green-500' : 'bg-gray-400' %>"></span>
                <span class="font-medium text-gray-900 dark:text-gray-100 truncate"><%= project.name %></span>
              </div>
              <% if project.description.present? %>
                <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mb-3"><%= project.description %></p>
              <% else %>
                <p class="text-xs text-gray-400 dark:text-gray-500 italic mb-3">No description</p>
              <% end %>
              <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
                <span><%= pluralize(total, "issue") %></span>
                <span><%= progress %>% done</span>
              </div>
              <div class="mt-2 h-1.5 rounded-full bg-gray-100 dark:bg-gray-800 overflow-hidden">
                <div class="h-full rounded-full bg-indigo-500 dark:bg-indigo-400" style="width: <%= progress %>%"></div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-md p-8 text-center bg-white dark:bg-gray-900">
          <p class="text-gray-600 dark:text-gray-400 mb-4">No projects yet.</p>
          <% if current_membership&.admin? || current_membership&.manager? %>
            <%= link_to "Create the first project", new_project_path,
                  class: "bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:hover:bg-white" %>
          <% end %>
        </div>
      <% end %>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- My open issues -->
      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">My open issues</h2>
          <span class="text-xs text-gray-400 dark:text-gray-500"><%= @my_open_issues.size %></span>
        </div>
        <% if @my_open_issues.any? %>
          <ul class="divide-y divide-gray-200 dark:divide-gray-800 border border-gray-200 dark:border-gray-800 rounded-md bg-white dark:bg-gray-900">
            <% @my_open_issues.each do |issue| %>
              <li>
                <%= link_to [ issue.project, issue ], class: "block px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800" do %>
                  <div class="flex items-center justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-0.5"><%= issue.project.slug %>-#<%= issue.number %></div>
                      <div class="text-sm text-gray-900 dark:text-gray-100 truncate"><%= issue.title %></div>
                    </div>
                    <div class="shrink-0 flex items-center gap-2">
                      <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= status_badge_class(issue.status) %>">
                        <%= issue.status.humanize %>
                      </span>
                      <% if issue.due_date %>
                        <span class="text-xs <%= issue.due_date < Date.current ? 'text-red-600 dark:text-red-300' : 'text-gray-500 dark:text-gray-400' %>">
                          <%= issue.due_date.to_fs(:long) %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-md p-6 text-center bg-white dark:bg-gray-900">
            <p class="text-sm text-gray-500 dark:text-gray-400">Nothing assigned to you right now.</p>
          </div>
        <% end %>
      </section>

      <!-- Recent activity -->
      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Recent activity</h2>
          <%= link_to "All", activity_path, class: "text-xs text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
        </div>
        <% if @recent_activity.any? %>
          <ul class="divide-y divide-gray-200 dark:divide-gray-800 border border-gray-200 dark:border-gray-800 rounded-md bg-white dark:bg-gray-900">
            <% @recent_activity.each do |event| %>
              <li class="px-4 py-3 flex items-start gap-3">
                <div class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-xs">
                  <%= activity_icon(event) %>
                </div>
                <div class="flex-1 min-w-0 text-sm">
                  <div class="text-gray-800 dark:text-gray-200"><%= activity_description(event) %></div>
                  <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= time_ago_in_words(event.created_at) %> ago</div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-md p-6 text-center bg-white dark:bg-gray-900">
            <p class="text-sm text-gray-500 dark:text-gray-400">No activity yet. Create a project or open an issue.</p>
          </div>
        <% end %>
      </section>
    </div>
  </div>

  <% content_for :right_rail do %>
    <%= render "dashboard/right_rail" %>
  <% end %>
<% else %>
  <div class="px-6 py-10 max-w-3xl">
    <h1 class="text-2xl font-semibold mb-2">Welcome to Tracklane</h1>
    <p class="text-gray-600 dark:text-gray-400">You are not a member of any organization yet. Ask an admin to invite you.</p>
  </div>
<% end %>
