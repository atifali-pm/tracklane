<div class="max-w-3xl mx-auto py-12 px-4">
  <h1 class="text-2xl font-semibold mb-2">Tracklane</h1>
  <p class="text-gray-600 mb-8">Signed in as <%= Current.user.email_address %>.</p>

  <h2 class="text-lg font-medium mb-3">Your organizations</h2>
  <ul class="divide-y divide-gray-200 border border-gray-200 rounded-md">
    <% @memberships.each do |m| %>
      <li class="px-4 py-3 flex items-center justify-between">
        <div>
          <div class="font-medium"><%= m.organization.name %></div>
          <div class="text-sm text-gray-500"><%= m.organization.slug %></div>
        </div>
        <span class="inline-flex items-center px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-700">
          <%= m.role %>
        </span>
      </li>
    <% end %>
  </ul>

  <%= button_to "Sign out", session_path, method: :delete, class: "mt-8 text-sm text-gray-600 hover:text-gray-900 underline" %>
</div>
