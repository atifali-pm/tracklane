<li id="<%= dom_id(event) %>" class="flex items-start gap-3 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md px-4 py-3">
  <div class="shrink-0 w-7 h-7 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-sm">
    <%= activity_icon(event) %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="text-sm text-gray-900 dark:text-gray-100">
      <%= activity_description(event) %>
    </div>
    <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
      <%= time_ago_in_words(event.created_at) %> ago
    </div>
  </div>
</li>
