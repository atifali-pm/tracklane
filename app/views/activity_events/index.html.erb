<%= turbo_stream_from [ current_organization, :activity ] %>

<div class="max-w-3xl mx-auto py-10 px-4">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Activity</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400">Recent events in <%= current_organization.name %>.</p>
  </div>

  <ul id="activity_feed" class="space-y-2">
    <% @events.each do |event| %>
      <%= render "activity_events/event", event: event %>
    <% end %>
  </ul>

  <% if @events.empty? %>
    <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-md p-8 text-center bg-white dark:bg-gray-900">
      <p class="text-gray-600 dark:text-gray-400">No activity yet. Create a project or open an issue.</p>
    </div>
  <% end %>
</div>
