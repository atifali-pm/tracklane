<% content_for :title, "Workload" %>

<div class="px-6 py-6 max-w-6xl">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Workload</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
      Open issues across <%= current_organization.name %> grouped by assignee.
    </p>
  </div>

  <% if @rows.any? %>
    <div class="overflow-x-auto bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-800 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
            <th class="text-left font-medium px-4 py-3">Assignee</th>
            <% WorkloadsController::STATUS_ORDER.each do |status| %>
              <th class="text-center font-medium px-3 py-3 capitalize"><%= status.humanize %></th>
            <% end %>
            <th class="text-center font-medium px-4 py-3">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
          <% @rows.each do |row| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
              <td class="px-4 py-3">
                <% if row[:user] %>
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-800 text-indigo-700 dark:text-indigo-200 text-[10px] flex items-center justify-center font-semibold">
                      <%= row[:user].email_address.first.upcase %>
                    </div>
                    <div class="text-sm text-gray-900 dark:text-gray-100"><%= row[:user].email_address %></div>
                  </div>
                <% else %>
                  <div class="text-sm text-gray-500 dark:text-gray-400 italic">Unassigned</div>
                <% end %>
              </td>
              <% WorkloadsController::STATUS_ORDER.each do |status| %>
                <% count = row[:counts][status] %>
                <td class="px-3 py-3 text-center">
                  <% if count > 0 %>
                    <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= status_badge_class(status) %>">
                      <%= count %>
                    </span>
                  <% else %>
                    <span class="text-gray-300 dark:text-gray-600 text-xs">·</span>
                  <% end %>
                </td>
              <% end %>
              <td class="px-4 py-3 text-center font-medium text-gray-900 dark:text-gray-100"><%= row[:total] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-md p-10 text-center bg-white dark:bg-gray-900">
      <p class="text-gray-600 dark:text-gray-400">No issues in this organization yet.</p>
    </div>
  <% end %>
</div>
