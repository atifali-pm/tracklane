<%= form_with model: [ @project, issue ], class: "space-y-5" do |f| %>
  <% if issue.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-900 text-red-800 dark:text-red-200 rounded-md p-3 text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% issue.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :title, required: true, autofocus: true,
          class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:outline-blue-600 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_area :description, rows: 10,
          class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:outline-blue-600 px-3 py-2 font-mono text-sm" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :status, Issue.statuses.keys.map { |s| [ s.humanize, s ] },
            {}, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :priority, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :priority, Issue.priorities.keys.map { |p| [ p.humanize, p ] },
            {}, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :assignee_id, "Assignee", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :assignee_id,
            options_for_select([ [ "Unassigned", nil ] ] + @eligible_assignees.map { |u| [ u.email_address, u.id ] }, issue.assignee_id),
            {}, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :due_date, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.date_field :due_date,
            class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 px-3 py-2" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white cursor-pointer" %>
    <%= link_to "Cancel", (issue.persisted? ? [ @project, issue ] : project_issues_path(@project)),
          class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
  </div>
<% end %>
