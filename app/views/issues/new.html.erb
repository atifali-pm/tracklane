<div class="max-w-2xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to "#{@project.name} issues", project_issues_path(@project), class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>

  <h1 class="text-2xl font-semibold mb-2">New issue</h1>
  <p class="text-sm text-gray-500 mb-6">In <%= @project.name %></p>

  <% if @issue.new_record? && @issue.description.blank? %>
    <div class="mb-6 p-4 border border-gray-200 rounded-md bg-white">
      <div class="text-sm font-medium text-gray-700 mb-2">Start from a template</div>
      <div class="flex flex-wrap gap-2">
        <% IssueTemplate.all.each do |key, meta| %>
          <%= link_to meta[:label], new_project_issue_path(@project, template: key),
                class: "text-sm border border-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "form", issue: @issue %>
</div>
