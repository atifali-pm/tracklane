<div class="max-w-5xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to @project.name, @project, class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Issues</h1>
      <p class="text-sm text-gray-500"><%= @project.name %></p>
    </div>
    <% if %w[admin manager member].include?(current_membership&.role.to_s) %>
      <%= link_to "New issue", new_project_issue_path(@project),
            class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800" %>
    <% end %>
  </div>

  <div class="mb-4 flex items-center gap-2 text-sm">
    <%= link_to "All", project_issues_path(@project),
          class: "px-3 py-1.5 rounded-md #{params[:status].blank? ? 'bg-gray-900 text-white' : 'bg-white border border-gray-200 text-gray-700 hover:bg-gray-100'}" %>
    <% Issue.statuses.keys.each do |status| %>
      <%= link_to status.humanize, project_issues_path(@project, status: status),
            class: "px-3 py-1.5 rounded-md #{params[:status] == status ? 'bg-gray-900 text-white' : 'bg-white border border-gray-200 text-gray-700 hover:bg-gray-100'}" %>
    <% end %>
  </div>

  <% if @issues.any? %>
    <ul class="divide-y divide-gray-200 border border-gray-200 rounded-md bg-white">
      <% @issues.each do |issue| %>
        <li class="px-4 py-4 hover:bg-gray-50">
          <%= link_to [ @project, issue ], class: "flex items-start justify-between" do %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-gray-400 font-mono">#<%= issue.number %></span>
                <span class="font-medium text-gray-900 truncate"><%= issue.title %></span>
              </div>
              <div class="flex items-center gap-3 text-xs text-gray-500">
                <span class="capitalize"><%= issue.status.humanize %></span>
                <span>·</span>
                <span class="capitalize">priority: <%= issue.priority %></span>
                <% if issue.assignee %>
                  <span>·</span>
                  <span>@<%= issue.assignee.email_address.split('@').first %></span>
                <% end %>
                <% if issue.due_date %>
                  <span>·</span>
                  <span>due <%= issue.due_date.to_fs(:long) %></span>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-2 ml-4 shrink-0">
              <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= status_badge_class(issue.status) %>">
                <%= issue.status.humanize %>
              </span>
              <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= priority_badge_class(issue.priority) %>">
                <%= issue.priority %>
              </span>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="border border-dashed border-gray-300 rounded-md p-10 text-center bg-white">
      <p class="text-gray-600 mb-4">No issues yet.</p>
      <% if %w[admin manager member].include?(current_membership&.role.to_s) %>
        <%= link_to "Open the first issue", new_project_issue_path(@project),
              class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800" %>
      <% end %>
    </div>
  <% end %>
</div>
