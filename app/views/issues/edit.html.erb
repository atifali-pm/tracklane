<div class="max-w-2xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to "#{@project.slug}-##{@issue.number}", [ @project, @issue ], class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-white" %>
  </div>

  <h1 class="text-2xl font-semibold mb-6">Edit issue</h1>

  <%= render "form", issue: @issue %>
</div>
