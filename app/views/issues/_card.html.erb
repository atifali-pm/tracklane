<li id="<%= dom_id(issue) %>"
    class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md p-3 shadow-xs hover:shadow-sm cursor-grab active:cursor-grabbing"
    data-issue-number="<%= issue.number %>"
    data-board-target="card"
    draggable="true">
  <%= link_to [ project, issue ], class: "block" do %>
    <div class="flex items-center gap-2 mb-1">
      <span class="text-xs text-gray-400 dark:text-gray-500 font-mono">#<%= issue.number %></span>
      <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] rounded-full capitalize <%= priority_badge_class(issue.priority) %>">
        <%= issue.priority %>
      </span>
    </div>
    <div class="text-sm font-medium text-gray-900 dark:text-gray-100 line-clamp-2">
      <%= issue.title %>
    </div>
    <% if issue.assignee || issue.due_date %>
      <div class="mt-2 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
        <% if issue.assignee %>
          <span>@<%= issue.assignee.email_address.split('@').first %></span>
        <% end %>
        <% if issue.due_date %>
          <span>·</span>
          <span>due <%= issue.due_date.to_fs(:long) %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</li>
