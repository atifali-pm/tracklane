<% content_for :title, "#{@project.name} calendar" %>

<div class="px-6 py-6 max-w-7xl">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <div class="mb-1">
        <%= link_to @project.name, @project, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-white" %>
      </div>
      <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= @current_month.strftime("%B %Y") %></h1>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "List", project_issues_path(@project), class: "text-sm border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100 dark:hover:bg-gray-800" %>
      <%= link_to "Board", project_board_path(@project), class: "text-sm border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100 dark:hover:bg-gray-800" %>
      <div class="flex items-center ml-2 rounded-md border border-gray-300 dark:border-gray-700 overflow-hidden">
        <%= link_to "‹", project_calendar_path(@project, month: @prev_month),
              class: "px-2 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800" %>
        <%= link_to "Today", project_calendar_path(@project, month: Date.current),
              class: "px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 border-l border-r border-gray-300 dark:border-gray-700" %>
        <%= link_to "›", project_calendar_path(@project, month: @next_month),
              class: "px-2 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800" %>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md overflow-hidden">
    <div class="grid grid-cols-7 border-b border-gray-200 dark:border-gray-800 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
      <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |label| %>
        <div class="px-2 py-2 text-center font-medium"><%= label %></div>
      <% end %>
    </div>

    <div class="grid grid-cols-7">
      <% @days.each do |day| %>
        <% in_month = day.month == @current_month.month %>
        <% is_today = day == Date.current %>
        <div class="min-h-[6.5rem] border-t border-r border-gray-200 dark:border-gray-800 px-2 py-1.5 <%= in_month ? '' : 'bg-gray-50 dark:bg-gray-950' %>">
          <div class="flex items-center justify-between mb-1">
            <span class="<%= is_today ? 'inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-600 text-white text-xs font-semibold' : "text-xs font-medium #{in_month ? 'text-gray-700 dark:text-gray-300' : 'text-gray-400 dark:text-gray-600'}" %>">
              <%= day.day %>
            </span>
          </div>
          <% (@issues_by_day[day] || []).each do |issue| %>
            <%= link_to [ @project, issue ],
                  class: "block px-1.5 py-1 mb-1 rounded text-[11px] leading-tight truncate #{status_badge_class(issue.status)} hover:opacity-80",
                  title: "#{issue.project.slug}-##{issue.number}: #{issue.title}" do %>
              #<%= issue.number %> <%= issue.title %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
