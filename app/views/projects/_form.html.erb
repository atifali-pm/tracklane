<%= form_with model: project, class: "space-y-5" do |f| %>
  <% if project.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-md p-3 text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, required: true, autofocus: true,
          class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
  </div>

  <% if project.persisted? %>
    <div>
      <%= f.label :slug, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :slug, required: true,
            class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
      <p class="text-xs text-gray-500 mt-1">Lowercase, numbers, dashes only. Changing this breaks existing links.</p>
    </div>
  <% end %>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4,
          class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
  </div>

  <% if project.persisted? %>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, Project.statuses.keys.map { |s| [ s.humanize, s ] },
            {}, class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= f.submit class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 cursor-pointer" %>
    <%= link_to "Cancel", (project.persisted? ? project : projects_path), class: "text-sm text-gray-600 hover:text-gray-900" %>
  </div>
<% end %>
