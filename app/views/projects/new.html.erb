<div class="max-w-xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to "All projects", projects_path, class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>
  <h1 class="text-2xl font-semibold mb-6">New project</h1>

  <div class="mb-6 p-4 border border-gray-200 rounded-md bg-white">
    <div class="text-sm font-medium text-gray-700 mb-2">Optional: start from a template</div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <% ProjectTemplate.all.each do |key, meta| %>
        <label class="block border rounded-md p-3 cursor-pointer hover:border-gray-400 <%= params[:template] == key ? 'border-gray-900 ring-1 ring-gray-900' : 'border-gray-200' %>">
          <input type="radio" name="project_template_radio" value="<%= key %>" class="sr-only" onchange="document.getElementById('project_template_input').value=this.value">
          <div class="font-medium text-sm text-gray-900"><%= meta[:label] %></div>
          <div class="text-xs text-gray-500 mt-1"><%= meta[:description] %></div>
          <div class="text-xs text-gray-400 mt-2"><%= meta[:starter_issues].size %> starter issues</div>
        </label>
      <% end %>
      <label class="block border rounded-md p-3 cursor-pointer hover:border-gray-400 <%= params[:template].blank? ? 'border-gray-900 ring-1 ring-gray-900' : 'border-gray-200' %>">
        <input type="radio" name="project_template_radio" value="" checked class="sr-only" onchange="document.getElementById('project_template_input').value=''">
        <div class="font-medium text-sm text-gray-900">Blank project</div>
        <div class="text-xs text-gray-500 mt-1">Start empty, no starter issues.</div>
      </label>
    </div>
  </div>

  <%= form_with model: @project, class: "space-y-5" do |f| %>
    <%= hidden_field_tag :template, params[:template], id: "project_template_input" %>
    <% if @project.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 rounded-md p-3 text-sm">
        <ul class="list-disc list-inside space-y-1">
          <% @project.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, required: true, autofocus: true,
            class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 4,
            class: "block w-full rounded-md border border-gray-300 shadow-sm focus:outline-blue-600 px-3 py-2" %>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Create project", class: "bg-gray-900 text-white rounded-md px-4 py-2 text-sm hover:bg-gray-800 cursor-pointer" %>
      <%= link_to "Cancel", projects_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
