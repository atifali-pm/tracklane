<div class="max-w-4xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to "All projects", projects_path, class: "text-sm text-gray-500 hover:text-gray-800" %>
  </div>

  <div class="flex items-start justify-between mb-6">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <h1 class="text-2xl font-semibold"><%= @project.name %></h1>
        <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= @project.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>">
          <%= @project.status %>
        </span>
      </div>
      <p class="text-sm text-gray-500">/<%= @project.slug %></p>
    </div>
    <% if current_membership&.admin? || current_membership&.manager? %>
      <div class="flex items-center gap-2">
        <%= link_to "Edit", edit_project_path(@project),
              class: "text-sm border border-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100" %>
        <%= button_to "Delete", @project,
              method: :delete,
              data: { turbo_confirm: "Delete #{@project.name}? This cannot be undone." },
              class: "text-sm border border-red-300 text-red-700 rounded-md px-3 py-1.5 hover:bg-red-50 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <% if @project.description.present? %>
    <div class="bg-white border border-gray-200 rounded-md p-5 text-gray-700 whitespace-pre-wrap">
      <%= @project.description %>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 italic">No description yet.</p>
  <% end %>

  <div class="mt-8 bg-white border border-gray-200 rounded-md p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Issues</h2>
      <%= link_to "All issues", project_issues_path(@project), class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>

    <% recent = @project.issues.includes(:reporter, :assignee).ordered.limit(5) %>
    <% if recent.any? %>
      <ul class="divide-y divide-gray-200">
        <% recent.each do |issue| %>
          <li class="py-3">
            <%= link_to [ @project, issue ], class: "flex items-center justify-between" do %>
              <div class="flex items-center gap-2">
                <span class="text-xs text-gray-400 font-mono">#<%= issue.number %></span>
                <span class="text-gray-900"><%= issue.title %></span>
              </div>
              <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= status_badge_class(issue.status) %>">
                <%= issue.status.humanize %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">No issues yet.</p>
    <% end %>

    <% if %w[admin manager member].include?(current_membership&.role.to_s) %>
      <div class="mt-4">
        <%= link_to "New issue", new_project_issue_path(@project),
              class: "inline-flex items-center bg-gray-900 text-white rounded-md px-3 py-1.5 text-sm hover:bg-gray-800" %>
      </div>
    <% end %>
  </div>
</div>
