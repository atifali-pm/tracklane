<div class="max-w-4xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to "All projects", projects_path, class: "text-sm text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-white" %>
  </div>

  <div class="flex items-start justify-between mb-6">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <h1 class="text-2xl font-semibold"><%= @project.name %></h1>
        <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= @project.active? ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-200' : 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400' %>">
          <%= @project.status %>
        </span>
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400">/<%= @project.slug %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Board", project_board_path(@project),
            class: "text-sm border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100 dark:hover:bg-gray-800" %>
      <%= link_to "Calendar", project_calendar_path(@project),
            class: "text-sm border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100 dark:hover:bg-gray-800" %>
      <%= link_to "Ask AI", project_ask_path(@project),
            class: "text-sm border border-indigo-300 dark:border-indigo-800 text-indigo-700 dark:text-indigo-300 rounded-md px-3 py-1.5 hover:bg-indigo-50 dark:hover:bg-indigo-900/30" %>
      <% if current_membership&.admin? || current_membership&.manager? %>
        <%= link_to "Edit", edit_project_path(@project),
              class: "text-sm border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-md px-3 py-1.5 hover:bg-gray-100 dark:hover:bg-gray-800" %>
        <%= button_to "Delete", @project,
              method: :delete,
              data: { turbo_confirm: "Delete #{@project.name}? This cannot be undone." },
              class: "text-sm border border-red-300 dark:border-red-900 text-red-700 dark:text-red-300 rounded-md px-3 py-1.5 hover:bg-red-50 dark:hover:bg-red-900/30 cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <% if @project.description.present? %>
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md p-5 text-gray-700 dark:text-gray-200 whitespace-pre-wrap">
      <%= @project.description %>
    </div>
  <% else %>
    <p class="text-sm text-gray-500 dark:text-gray-400 italic">No description yet.</p>
  <% end %>

  <div class="mt-8 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Issues</h2>
      <%= link_to "All issues", project_issues_path(@project), class: "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
    </div>

    <% recent = @project.issues.includes(:reporter, :assignee).ordered.limit(5) %>
    <% if recent.any? %>
      <ul class="divide-y divide-gray-200 dark:divide-gray-800">
        <% recent.each do |issue| %>
          <li class="py-3">
            <%= link_to [ @project, issue ], class: "flex items-center justify-between" do %>
              <div class="flex items-center gap-2">
                <span class="text-xs text-gray-400 dark:text-gray-500 font-mono">#<%= issue.number %></span>
                <span class="text-gray-900 dark:text-gray-100"><%= issue.title %></span>
              </div>
              <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full capitalize <%= status_badge_class(issue.status) %>">
                <%= issue.status.humanize %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500 dark:text-gray-400">No issues yet.</p>
    <% end %>

    <% if %w[admin manager member].include?(current_membership&.role.to_s) %>
      <div class="mt-4">
        <%= link_to "New issue", new_project_issue_path(@project),
              class: "inline-flex items-center bg-gray-900 text-white rounded-md px-3 py-1.5 text-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white" %>
      </div>
    <% end %>
  </div>
</div>
