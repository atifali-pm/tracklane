<% if Current.user %>
  <nav class="border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-8">
        <%= link_to root_path, class: "font-semibold text-gray-900 dark:text-gray-100 hover:text-gray-700 dark:hover:text-white" do %>
          Tracklane
        <% end %>

        <% if current_organization %>
          <div class="flex items-center gap-5">
            <%= link_to "Projects", projects_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %>
            <%= link_to "Activity", activity_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %>
            <% if current_membership&.admin? %>
              <%= link_to "Invitations", invitations_path, class: "text-sm text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %>
            <% end %>

            <div class="text-sm text-gray-500 dark:text-gray-400">
              <span class="text-gray-400 dark:text-gray-500">org:</span>
              <span class="font-medium text-gray-800 dark:text-gray-200"><%= current_organization.name %></span>
              <% if current_membership %>
                <span class="ml-2 inline-flex items-center px-2 py-0.5 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 capitalize">
                  <%= current_membership.role %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex items-center gap-4">
        <% if available_organizations.count > 1 %>
          <details class="relative">
            <summary class="cursor-pointer list-none text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">
              Switch org
            </summary>
            <div class="absolute right-0 mt-2 w-56 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-md shadow-sm z-10">
              <% available_organizations.each do |org| %>
                <%= button_to switch_organization_path(org.slug),
                      method: :patch,
                      class: "w-full text-left px-3 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-800 #{'font-semibold text-gray-900 dark:text-gray-100' if org == current_organization}" do %>
                  <%= org.name %>
                  <div class="text-xs text-gray-500 dark:text-gray-400"><%= org.slug %></div>
                <% end %>
              <% end %>
            </div>
          </details>
        <% end %>

        <%= button_to user_preferences_path(theme: (theme_preference == "dark" ? "light" : "dark")),
              method: :patch,
              class: "text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white cursor-pointer" do %>
          <% if theme_preference == "dark" %>
            ☀ Light
          <% else %>
            ☾ Dark
          <% end %>
        <% end %>

        <span class="text-sm text-gray-500 dark:text-gray-400"><%= Current.user.email_address %></span>
        <%= button_to "Sign out", session_path, method: :delete, class: "text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white underline" %>
      </div>
    </div>
  </nav>
<% end %>

<% if flash[:notice].present? %>
  <div class="bg-green-50 dark:bg-green-900/30 border-b border-green-200 dark:border-green-900 text-green-800 dark:text-green-200 text-sm px-4 py-2 text-center">
    <%= flash[:notice] %>
  </div>
<% end %>
<% if flash[:alert].present? %>
  <div class="bg-red-50 dark:bg-red-900/30 border-b border-red-200 dark:border-red-900 text-red-800 dark:text-red-200 text-sm px-4 py-2 text-center">
    <%= flash[:alert] %>
  </div>
<% end %>
