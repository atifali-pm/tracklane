<% if flash[:notice].present? %>
  <div class="bg-green-50 dark:bg-green-900/30 border-b border-green-200 dark:border-green-900 text-green-800 dark:text-green-200 text-sm px-6 py-2">
    <%= flash[:notice] %>
  </div>
<% end %>
<% if flash[:alert].present? %>
  <div class="bg-red-50 dark:bg-red-900/30 border-b border-red-200 dark:border-red-900 text-red-800 dark:text-red-200 text-sm px-6 py-2">
    <%= flash[:alert] %>
  </div>
<% end %>
