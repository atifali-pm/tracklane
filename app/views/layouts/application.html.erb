<!DOCTYPE html>
<html data-theme="<%= theme_preference %>">
  <head>
    <title><%= content_for(:title) || "Tracklane" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tracklane">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var el = document.documentElement;
        var t = el.dataset.theme;
        if (!t || t === "system") {
          el.dataset.theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        }
      })();
    </script>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
    <% if Current.user %>
      <div class="flex min-h-screen">
        <%= render "layouts/sidebar" %>

        <div class="flex-1 flex flex-col min-w-0">
          <%= render "layouts/topbar" %>

          <div class="flex-1 flex min-w-0">
            <main class="flex-1 min-w-0">
              <%= render "layouts/flash" %>
              <%= yield %>
            </main>

            <% if content_for?(:right_rail) %>
              <aside class="hidden xl:block w-80 shrink-0 border-l border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6">
                <%= yield :right_rail %>
              </aside>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <%= render "layouts/flash" %>
      <%= yield %>
    <% end %>
  </body>
</html>
